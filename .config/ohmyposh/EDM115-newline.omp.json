          "style": "powerline"
        },
        {
          "type": "project",
          "style": "powerline",
          "powerline_symbol": "оӮ°",
          "foreground": "p:color13",
          "background": "p:color10",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Version }}п’Ү {{.Version}}{{ end }} {{ if .Name }}{{ .Name }}{{ end }}{{ end }} "
        },
        {
          "type": "battery",
          "style": "powerline",
          "powerline_symbol": "оӮ°",
          "foreground": "p:color13",
          "background": "p:color10",
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}#40c4ff{{end}}",
            "{{if eq \"Discharging\" .State.String}}#ff5722{{end}}",
            "{{if eq \"Full\" .State.String}}#4caf50{{end}}"
          ],
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}пҠ• ",
          "properties": {
            "discharging_icon": "оҲұ ",
            "charging_icon": "оҲҙ ",
            "charged_icon": "оҲҜ "
